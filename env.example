# ============================================================
# AMAZON CREATORS API (substitui a PA API — credenciais no Associates Central)
# ============================================================
AMAZON_CREATORS_CREDENTIAL_ID=SEU_CREDENTIAL_ID_AQUI
AMAZON_CREATORS_CREDENTIAL_SECRET=SEU_CREDENTIAL_SECRET_AQUI
# 3.1 = LWA (credenciais atuais) | 2.1 / 2.2 / 2.3 = Cognito (credenciais antigas)
AMAZON_CREATORS_CREDENTIAL_VERSION=3.1
AMAZON_MARKETPLACE=www.amazon.com.br
# Opcional: token LWA por região (padrão NA = api.amazon.com). Europa: https://api.amazon.co.uk/auth/o2/token
# AMAZON_CREATORS_AUTH_ENDPOINT=
AMAZON_ASSOCIATE_TAG=melhoresofertasdaray-20
AMAZON_COUNTRY=BR
# Itens retornados por busca (1–100)
AMAZON_ITEM_COUNT=15

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# ============================================================
# GEMINI API (Nano Banana / Imagen)
# ============================================================
GEMINI_API_KEY=SUA_GEMINI_API_KEY_AQUI

# ============================================================
# BUFFER API
# ============================================================
BUFFER_ACCESS_TOKEN=SEU_BUFFER_TOKEN_AQUI
BUFFER_PROFILE_ID_INSTAGRAM=SEU_PROFILE_ID_INSTAGRAM
BUFFER_PROFILE_ID_FACEBOOK=SEU_PROFILE_ID_FACEBOOK

# ============================================================
# SCHEDULER — Horários de execução (formato HH:MM, separados por vírgula)
# ============================================================
SCHEDULE_TIMES=08:00,12:00,18:00,21:00

# ============================================================
# FILTROS DE PRODUTO
# ============================================================
MIN_RATING=4.0
MIN_REVIEWS=50
MAX_PRICE=500.00
PRODUCTS_PER_RUN=1

# ============================================================
# CATEGORIAS ATIVAS (separadas por vírgula)
# Opções: HomeAndKitchen, BeautyAndPersonalCare, SportsAndOutdoors, Electronics
# ============================================================
ACTIVE_CATEGORIES=HomeAndKitchen,BeautyAndPersonalCare,SportsAndOutdoors,Electronics
